# Aegisure launch configuration.
# Copy only the variables needed by each service. Replace placeholders in hosted env settings.
# Do not commit real secrets.

###############################################################################
# Vercel (frontend: apps/web) - public NEXT_PUBLIC values only
###############################################################################

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
NEXT_PUBLIC_API_URL=https://your-railway-backend.up.railway.app

###############################################################################
# Railway (backend: apps/backend) - secrets/server-only values
###############################################################################

# Supabase Postgres. Use the SQLAlchemy/psycopg form.
DATABASE_URL=postgresql+psycopg://postgres:replace_me@db.your-project.supabase.co:5432/postgres

# Supabase Auth/JWT verification.
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret

# GitHub App. Paste the PEM contents into AEGISURE_GITHUB_APP_PRIVATE_KEY, not a path.
AEGISURE_GITHUB_APP_ID=123456
AEGISURE_GITHUB_WEBHOOK_SECRET=replace-with-github-webhook-secret
AEGISURE_GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_me\n-----END PRIVATE KEY-----"

# CORS. Set this to your Vercel frontend origin.
ALLOWED_ORIGINS=https://aegisure.dev

# Optional LLM reasoning. Static analysis works with these unset/blank.
AEGISURE_ANTHROPIC_API_KEY=
AEGISURE_OPENAI_API_KEY=
AEGISURE_ENABLE_SECOND_OPINION=false
AEGISURE_ANTHROPIC_REVIEW_MODEL=claude-3-5-haiku-latest
AEGISURE_OPENAI_REVIEW_MODEL=gpt-4.1-mini
AEGISURE_PROVIDED_DAILY_CAP_USD=0.25

# Optional observability.
SENTRY_DSN=

###############################################################################
# Local development only
###############################################################################

AEGISURE_API_TOKEN=replace-with-long-random-dev-api-token
AEGISURE_WORKSPACE_ID=local
AEGISURE_DEV_AUTH=false
PUBLIC_BASE_URL=https://aegisure.dev
