# Aegisure launch configuration. Replace placeholders in your own environment.

# Local dashboard/backend dev auth. Use a long random value.
AEGISURE_API_TOKEN=replace-with-long-random-dev-api-token
AEGISURE_WORKSPACE_ID=local
AEGISURE_DEV_AUTH=false
AEGISURE_CORS_ORIGINS=http://localhost:3000

# Hosted database. Supabase Postgres should use this form.
DATABASE_URL=postgresql+psycopg://postgres:replace_me@db.your-project.supabase.co:5432/postgres

# Supabase Auth with GitHub provider.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me
SUPABASE_JWT_SECRET=replace_me
SUPABASE_JWT_AUDIENCE=authenticated

# GitHub App.
AEGISURE_GITHUB_APP_ID=123456
AEGISURE_GITHUB_APP_PRIVATE_KEY_PATH=/secure/path/github-app-private-key.pem
AEGISURE_GITHUB_WEBHOOK_SECRET=replace-with-webhook-secret

# Optional LLM reasoning. Static analysis works with all of these blank.
AEGISURE_ANTHROPIC_API_KEY=
AEGISURE_OPENAI_API_KEY=
AEGISURE_ANTHROPIC_REVIEW_MODEL=claude-3-5-haiku-latest
AEGISURE_OPENAI_REVIEW_MODEL=gpt-4.1-mini
AEGISURE_OLLAMA_MODEL=llama3.2
AEGISURE_PROVIDED_DAILY_CAP_USD=0.25
AEGISURE_ENABLE_SECOND_OPINION=false

# Observability; optional and env-gated.
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Deployment.
NEXT_PUBLIC_AEGISURE_BACKEND_URL=http://127.0.0.1:8000
AEGISURE_BACKEND_URL=http://127.0.0.1:8000
PUBLIC_BASE_URL=https://aegisure.dev
